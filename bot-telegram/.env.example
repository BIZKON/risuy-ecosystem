# Скопируй в .env (он в .gitignore) и заполни своими значениями.

# Токен бота от @BotFather
BOT_TOKEN=123456789:AA...replace_me

# Строка подключения к Timeweb Managed PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Канал для гейта подписки. Бот должен быть АДМИНОМ канала.
# Публичный канал: @username. Приватный/по id: -100xxxxxxxxxx
CHANNEL_ID=@risuysdushoy
# Ссылка для подписки, которую видит человек
CHANNEL_URL=https://t.me/risuysdushoy

# Ссылка на гайд (GetCourse) — выдаётся после воронки
GUIDE_URL=https://your-getcourse.example/pl/...

# Политика обработки ПДн (желательно для 152-ФЗ; можно оставить пустым)
PRIVACY_URL=https://your-site.example/privacy

# file_id видео-кружка Насти (необязательно; как получить — см. README)
VIDEO_NOTE_FILE_ID=

# Тайминги прогрева в секундах (по умолчанию +1ч / +1д / +3д)
FOLLOW_UP_1_DELAY=3600
FOLLOW_UP_2_DELAY=86400
FOLLOW_UP_3_DELAY=259200

# Порт health-эндпоинта + публичного /r-редиректа (App Platform обычно задаёт PORT сам)
PORT=8080

# ── Рассылки / очередь / трекинг (worker.run, /r) ────────────────────────────
# Публичный базовый URL БОТА (его поддомен на Timeweb) — на нём живёт /r/<token>.
# Ссылка {link} в рассылке = BOT_PUBLIC_BASE_URL + /r/<click_token>. Пусто = без трекинга.
BOT_PUBLIC_BASE_URL=https://your-bot-subdomain.example
# Служебный чат для ПЕРВИЧНОЙ заливки файла рассылки (НЕ первый получатель). chat_id
# гарантированно доступного чата/админа. Пусто = файловые рассылки не материализуются.
OPS_CHAT_ID=
# Единый rate-limit на ВЕСЬ исходящий трафик бота (token-bucket), msg/s.
BROADCAST_RATE=15
BROADCAST_BATCH=50
OUTBOX_BATCH=20
MAX_SEND_ATTEMPTS=3
# Reclaim застрявших 'sending' (краш/редеплой), сек. 600 > rolling-overlap Timeweb.
RECLAIM_AFTER_SECONDS=600
# Circuit-breaker молодого бота: при доле failed среди первых N > порога — авто-пауза.
CB_MIN_SAMPLE=20
CB_FAIL_RATIO=0.30

# ── Retention (152-ФЗ; retention.run) ───────────────────────────────────────
# Обезличивание по отзыву согласия: erase_requested_at + N дней. Совпадает с панелью.
ERASE_AFTER_DAYS=30
# Абсолютный TTL содержимого переписки (самый объёмный ПДн-поток), дни.
MESSAGES_TTL_DAYS=90
