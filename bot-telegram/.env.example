# Скопируй в .env (он в .gitignore) и заполни своими значениями.

# Токен бота от @BotFather
BOT_TOKEN=123456789:AA...replace_me

# Строка подключения к Timeweb Managed PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Канал для гейта подписки. Бот должен быть АДМИНОМ канала.
# Публичный канал: @username. Приватный/по id: -100xxxxxxxxxx
CHANNEL_ID=@risuysdushoy
# Ссылка для подписки, которую видит человек
CHANNEL_URL=https://t.me/risuysdushoy

# Ссылка на гайд (GetCourse) — выдаётся после воронки
GUIDE_URL=https://your-getcourse.example/pl/...

# Политика обработки ПДн (желательно для 152-ФЗ; можно оставить пустым)
PRIVACY_URL=https://your-site.example/privacy

# file_id видео-кружка Насти (необязательно; как получить — см. README)
VIDEO_NOTE_FILE_ID=

# Тайминги прогрева в секундах (по умолчанию +1ч / +1д / +3д)
FOLLOW_UP_1_DELAY=3600
FOLLOW_UP_2_DELAY=86400
FOLLOW_UP_3_DELAY=259200

# Порт health-эндпоинта (App Platform обычно задаёт PORT сам)
PORT=8080
